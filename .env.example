# Postgres connection string (Vercel Postgres or Neon). Prisma reads this.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Secret used to sign login session JWTs — set to a long random string.
JWT_SECRET="change-me-to-a-long-random-string"

# Optional: Vercel Blob token for delivery/incident photos.
# Without it the app still works; photos just are not stored.
BLOB_READ_WRITE_TOKEN=""
